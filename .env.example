# PostgreSQL connection used by the Express API.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Optional. Defaults to 3000.
PORT=3000

# Optional. Set to true only when your PostgreSQL server requires SSL.
DATABASE_SSL=false

# Optional. In production, secure cookies are enabled by default.
# Set COOKIE_SECURE=false only when deploying behind plain HTTP.
COOKIE_SECURE=true